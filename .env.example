# Superlista — Variables de Entorno
# Copia este archivo como .env y completa los valores

# Django
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,superlista.skylabs.cl

# Base de Datos (MySQL)
DB_NAME=super_lista
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
